<% layout("/Boilerplate/boilerplate.ejs") %>

<section class="max-w-6xl mx-auto py-16 px-6">
  <div class="grid md:grid-cols-1 gap-10 items-center">
    <div>

      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        <%= project.title %>
      </h1>

      <p class="text-gray-600 mb-6">
        <%= project.description %>
      </p>
    <div>
      <img 
        src="<%= project.images || '../images/rohit1.jpg' %>" 
        class="w-full rounded-xl shadow-md object-cover"
      >
    </div>
      <div class="flex flex-wrap gap-2 mb-6 mt-6">

        <% project.techStack.forEach((tech) => { %>

          <span class="bg-orange-100 text-orange-600 px-3 py-1 rounded text-sm font-medium">
            <%= tech %>
          </span>

        <% }) %>

      </div>

      <!-- Buttons -->
      <div class="flex gap-4">

        <% if(project.liveLink) { %>

          <a href="<%= project.liveLink %>" target="_blank"
             class="bg-blue-500 hover:bg-blue-600 text-white px-5 py-2 rounded-lg font-semibold transition">

             Live Demo

          </a>

        <% } %>


        <% if(project.githubLink) { %>

          <a href="<%= project.githubLink %>" target="_blank"
             class="bg-gray-800 hover:bg-black text-white px-5 py-2 rounded-lg font-semibold transition">

             GitHub

          </a>

        <% } %>

      </div>

    </div>

  </div>


  <!-- Detailed Section -->
  <div class="mt-16">

    <h2 class="text-2xl font-bold mb-4">
      Project Overview
    </h2>

    <p class="text-gray-700 leading-relaxed whitespace-pre-line">
      <%= project.fullDescription || project.description %>
    </p>

  </div>

  <% if(project.features && project.features.length > 0) { %>

  <div class="mt-12">

    <h2 class="text-2xl font-bold mb-4">
      Key Features
    </h2>

    <ul class="space-y-2">

      <% project.features.forEach((feature) => { %>

        <li class="flex items-center gap-2 text-gray-700">

          <i class="fa-solid fa-circle-check text-orange-500"></i>

          <%= feature %>

        </li>

      <% }) %>

    </ul>

  </div>

  <% } %>


</section>