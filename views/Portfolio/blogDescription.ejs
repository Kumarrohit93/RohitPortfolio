<% layout("/Boilerplate/boilerplate.ejs") %>

<section class="max-w-4xl mx-auto py-16 px-6 ">
  <img
    src="<%= blogs.coverImage %>"
    class="w-full h-80 object-cover rounded-lg mb-6 border-1 border-gray-400 p-4"
  />

  <span class="bg-orange-100 text-orange-600 px-3 py-1 rounded">
    <%= blogs.category %>
  </span>

  <h1 class="text-3xl font-bold mt-4 mb-4"><%= blogs.title %></h1>

  <p class="text-gray-500 mb-6">
    <%= blogs.createdAt.toDateString() %> • <%= blogs.readTime %> min read
  </p>

  <p class="text-gray-700 leading-relaxed whitespace-pre-line">
    <%= blogs.content %>
  </p>
</section>
