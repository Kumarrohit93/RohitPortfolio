<section
  class="w-full flex flex-col justify-center items-center transition-all p-16 bg-gray-50"
>
  <div class="text-center mb-4">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
      Clients and People <span class="text-orange-500">Reviews</span>
    </h2>

    <p class="text-gray-600 mt-3 max-w-xl mx-auto">
      Feedback from clients and collaborators who have worked with me.
    </p>
  </div>
  <button
    id="reviewBtn"
    class="bg-[#FA6920] hover:bg-orange-600 text-white px-6 py-2 rounded-md font-semibold transition"
  >
    Create a review
  </button>

  <form
    action="/client-review"
    method="POST"
    id="form"
    class="hidden w-full max-w-lg mx-auto bg-white border border-gray-200 rounded-lg mt-4 shadow-sm p-6 space-y-5"
  >
    <!-- Heading -->
    <div class="flex justify-between items-center">
      <div>
        <h2 class="text-xl text-center md:text-2xl font-bold text-gray-800">
          Leave a <span class="bg-orange-200 px-2 rounded">Review</span>
        </h2>

        <p class="text-sm text-gray-500 mt-1">
          Share your experience working with me
        </p>
      </div>

      <!-- Close button -->
      <button
        type="button"
        id="closeBtn"
        class="text-gray-500 hover:text-red-500 mt-[-1.5rem] text-2xl transition"
      >
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <!-- Name -->
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">
        Your Name
      </label>

      <input
        type="text"
        name="username"
        required
        placeholder="Enter your name"
        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400"
      />
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">
        Job Title
      </label>

      <input
        type="text"
        name="jobTitle"
        required
        placeholder="Enter your name"
        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400"
      />
    </div>

    <!-- Image -->
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">
        Profile Image
      </label>

      <input
        type="text"
        name="image"
        accept="image/*"
        class="w-full text-sm border border-gray-300 rounded-md p-2 file:bg-orange-500 file:text-white file:border-0 file:px-3 file:py-1 file:rounded file:cursor-pointer"
      />
    </div>

    <!-- Review -->
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">
        Your Review
      </label>

      <textarea
        name="feedback"
        required
        rows="4"
        placeholder="Write your feedback..."
        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400"
      ></textarea>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">
        Rating
      </label>

      <input
        type="number"
        name="rating"
        min="1"
        max="5"
        placeholder="Enter Rating"
        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400"
      />
    </div>

    <button
      type="submit"
      class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 rounded-md transition"
    >
      Submit Review
    </button>
  </form>

  <div class="max-w-7xl mx-auto grid gap-6 mt-4 sm:grid-cols-2 lg:grid-cols-3">

    <% if(reviewData.length === 0) { %>
        <p class="text-gray-500 text-center mt-6 text-lg font-semibold">
    No reviews yet
  </p>
     <% } else { %>
    <% reviewData.forEach(review => { %>
      
      <div
      class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm hover:shadow-md transition"
    >
      <div class="flex items-center gap-4">
        <img
          src="<%= review.image %>"
          class="w-14 h-14 rounded-full object-cover"
        />

        <div>
          <h3 class="font-semibold text-gray-800"><%= review.username %></h3>

          <p class="text-sm text-gray-500"><%= review.jobTitle %></p>
        </div>
      </div>

      <div class="flex gap-1 mt-3 text-orange-400">
         <% for(let i = 1; i <= 5; i++) { %>
            <% if(i <= review.rating) { %>
                <i class="fa-solid fa-star"></i>
<% } else { %>
    <i class="fa-regular fa-star"></i>

    <% } %>

  <% } %>
      </div>

      <p class="text-gray-600 text-sm mt-3 leading-relaxed">
        <%= review.feedback %>
      </p>
    </div>

   <% })} %>;
  </div>
</section>
<script>
  document.addEventListener("click", function (e) {
    const form = document.getElementById("form");

    if (e.target.closest("#reviewBtn")) {
      form.classList.remove("hidden");
    }

    if (e.target.closest("#closeBtn")) {
      e.preventDefault();
      form.classList.add("hidden");
    }
  });
</script>
