<section class="flex flex-col items-center p-6 gap-4">

  <!-- Heading -->
  <div class="text-center">

    <h1 class="text-3xl font-bold text-gray-900">
      My <span class="text-orange-500">Development Work</span>
    </h1>

    <p class="text-gray-600">
      Diverse Range of Projects from desktop to web Applications
    </p>

  </div>


  <!-- Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 px-6 py-10 w-full max-w-7xl">


    <% projectData.forEach((project) => { %>

      <div
        class="flex flex-col justify-between p-6 border border-gray-200 bg-gray-50 rounded-lg shadow-sm hover:shadow-md transition"
      >

        <!-- Top badges -->
        <div class="flex justify-between items-center mb-4">

          <% if(project.liveLink) { %>

            <span class="bg-orange-200 px-2 py-1 rounded text-xs font-semibold">
              Deployed
            </span>

          <% } else { %>

            <span class="bg-gray-200 px-2 py-1 rounded text-xs font-semibold">
              Not Live
            </span>

          <% } %>

          <span class="bg-blue-200 px-2 py-1 rounded text-xs font-semibold">
            Project
          </span>

        </div>


        <!-- Content -->
        <div>

          <h2 class="text-lg font-bold text-gray-800 mb-2">
            <%= project.title %>
          </h2>

          <p class="text-sm text-gray-600 mb-4">
            <%= project.description.split(" ").slice(0, 20).join(" ") %>
          </p>

        </div>


        <div class="flex flex-wrap gap-2 mb-4">

          <% project.techStack.forEach((tech) => { %>

            <span class="bg-orange-100 text-orange-600 text-xs px-2 py-1 rounded">
              <%= tech %>
            </span>

          <% }) %>

        </div>


        <div class="flex flex-wrap gap-2 mt-auto">

          <a
            href="<%= project.liveLink %>"
            target="_blank"
            class="bg-blue-500 hover:bg-blue-600 text-white text-sm px-3 py-1 rounded transition"
          >
            Live
          </a>

          <a
            href="<%= project.githubLink %>"
            target="_blank"
            class="bg-gray-800 hover:bg-black text-white text-sm px-3 py-1 rounded transition"
          >
            Code
          </a>

          <a
            href="/mywork/<%= project._id %>"
            target="_blank"
            class="bg-orange-400 hover:bg-black text-white text-sm px-3 py-1 rounded transition"
          >
            Description
          </a>

        </div>

      </div>

    <% }) %>


  </div>

</section>

