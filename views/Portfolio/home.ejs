<% layout("/Boilerplate/boilerplate") %>

<style>
  @keyframes slide {
    0% {
      transform: translateX(0%);
    }

    100% {
      transform: translateX(-100%);
    }
  }

  .animate-slide {
    animation: slide 5s linear infinite;
  }
</style>

<section
  class="min-h-[80vh] flex flex-col justify-center items-center px-6 py-12"
>
  <div
    class="w-32 h-32 md:w-40 md:h-40 grid items-center rounded-full overflow-hidden border-4 border-orange-400 shadow-md"
  >
    <img
      src="/images/rohit2.jpeg"
      alt="Rohit Kumar"
      class="w-full h-full object-cover"
    />
  </div>

  <h3 class="text-lg md:text-xl text-gray-600 mt-4">Hi, I'm Rohit Kumar</h3>

  <div class="text-center mt-3 space-y-2">
    <h1 class="text-2xl md:text-4xl font-bold text-gray-900 leading-tight">
      Passionate

      <span
        class="bg-orange-200 px-2 rounded-md inline-flex items-center gap-2"
      >
        Full-Stack
        <i class="fa-solid fa-user-tie"></i>
        Developer
      </span>
    </h1>

    <h1 class="text-2xl md:text-4xl font-bold mt-3 text-gray-900">
      <span class="bg-orange-200 px-2 rounded-md">Creating Innovative</span>
      Web Solutions
    </h1>
  </div>

  <p
    class="max-w-xl text-center text-gray-600 mt-6 text-sm md:text-base leading-relaxed"
  >
    Full Stack Developer skilled in building scalable web applications using
    MERN stack. I specialize in creating fast, responsive interfaces and secure
    backend systems that deliver real-world solutions.
  </p>

 <div class="flex gap-4 mt-6 flex-wrap">

  <a href="/resume/Rohit_Kumar_Resume.pdf" download
     class="bg-[#FA6920] hover:bg-orange-600 text-white px-6 py-2 rounded-md font-semibold transition flex items-center gap-2">

     <i class="fa-solid fa-download"></i>
     Download Resume

  </a>

  <a href="/mywork"
