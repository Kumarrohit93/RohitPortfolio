<% layout("/Boilerplate/adminboilerplate.ejs") %>

<div class="p-6">

  <!-- Heading -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">
      Create New Task
    </h1>
    <p class="text-gray-500">
      Add a new task to track your daily progress
    </p>
  </div>

  <div class="bg-white shadow-md rounded-lg p-6 w-full max-w-lg">

    <form action="/admin/create-task" method="POST" class="flex flex-col gap-4">
      <div>
        <label class="block text-gray-700 font-medium mb-1">
          Task Title
        </label>

        <input
          type="text"
          name="title"
          required
          placeholder="Enter task name (ex: DSA, MERN, Gym)"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400"
        >
      </div>
      <div>
        <label class="block text-gray-700 font-medium mb-1">
          Category
        </label>

        <input
          type="text"
          name="category"
          placeholder="learning/ personal / health / career"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400"
        >
      </div>

      <button
        type="submit"
        class="bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 rounded-md transition"
      >
        Create Task
      </button>

    </form>

  </div>
</div>

<div class="max-w-4xl mt-10">

  <h1 class="text-3xl font-bold text-gray-800 mb-6">
    All Tasks
  </h1>

  <% if(taskData.length === 0) { %>
    <p class="text-gray-500 text-center font-medium">
      No tasks available
    </p>
  <% } %>

  <div class="space-y-4">

    <% taskData.forEach(task => { %>

      <div class="bg-white shadow-md rounded-xl p-5 flex justify-between items-center hover:shadow-lg transition">

        <!-- Left Side -->
        <div>

          <h2 class="text-lg font-semibold text-gray-800">
            <%= task.title %>
          </h2>

          <div class="flex items-center gap-3 mt-1 text-sm text-gray-500">

            <span class="px-2 py-1 rounded bg-blue-100 text-blue-600 capitalize">
              <%= task.category %>
            </span>

            <span>
              <%= new Date(task.createdAt).toDateString() %>
            </span>

            <% if(task.isActive) { %>
              <span class="text-green-600 font-medium">
                Active
              </span>
            <% } else { %>
              <span class="text-red-500 font-medium">
                Inactive
              </span>
            <% } %>

          </div>

        </div>

        <!-- Right Side -->
        <div class="flex gap-2">

          <form action="/admin/delete/task/<%= task._id %>?_method=DELETE" method="POST">
            <button class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-semibold transition">
              Delete
            </button>
          </form>

        </div>

      </div>

    <% }) %>

  </div>

</div>