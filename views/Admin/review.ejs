<% layout("/Boilerplate/adminboilerplate.ejs") %>

<section
  class="w-full flex flex-col justify-start items-start transition-all p-4 bg-gray-50"
>
        <H1 class="text-2xl font-semibold">All Reviews</H1>


    <div class="max-w-7xl mx-auto grid gap-6 mt-4 sm:grid-cols-2 lg:grid-cols-3">
    <% if(reviewData.length === 0) { %>
        <p class="text-gray-500 text-center mt-6 text-lg font-semibold">
    No reviews yet
  </p>
     <% } else { %>
    <% reviewData.forEach(review => { %>
      
      <div
      class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm hover:shadow-md transition"
    >
      <div class="flex items-center gap-4">
        <img
          src="<%= review.image %>"
          class="w-14 h-14 rounded-full object-cover"
        />

        <div>
          <h3 class="font-semibold text-gray-800"><%= review.username %></h3>

          <p class="text-sm text-gray-500"><%= review.jobTitle %></p>
        </div>
      </div>

      <div class="flex gap-1 mt-3 text-orange-400">
         <% for(let i = 1; i <= 5; i++) { %>
            <% if(i <= review.rating) { %>
                <i class="fa-solid fa-star"></i>
<% } else { %>
    <i class="fa-regular fa-star"></i>

    <% } %>

  <% } %>
      </div>

      <p class="text-gray-600 text-sm mt-3 leading-relaxed">
        <%= review.feedback %>
      </p>

      <div>
        <form action="/admin/<%= review._id %>/review?_method=DELETE" method="post">
        <Button class="bg-[#FA6920] hover:bg-orange-600 text-white mt-4 px-6 py-2 rounded-md font-semibold transition">Delete</Button>

        </form>
    </div>
    </div>

    

   <% })} %>
  </div>
  </section>