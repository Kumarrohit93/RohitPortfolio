<% layout("/Boilerplate/adminboilerplate.ejs") %>

<style>

        table {
            border-collapse: collapse;
        }

        td, th {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
        }

        .completed {
            background-color: lightgreen;
        }

        .disabled {
            background-color: lightgray;
        }

    </style>s

<div class="flex flex-col gap-4 p-4">
    <div>
        <h1 class="text-3xl text-gray-700 font-bold">Welcome, <span class="text-orange-500">Rohit Kumar</span></h1>
    </div>
    <div class="flex justify-start items-start gap-2">
        <div class="p-8 bg-gray-100 text-2xl font-semibold rounded-lg">
            <h1>Total Projects: <span><%= project.length %></span></h1>
        </div>
        <div class="p-8 bg-gray-100 text-2xl font-semibold rounded-lg">
            <h1>Total Blogs: <span><%= blog.length %></span></h1>
        </div>
        <div class="p-8 bg-gray-100 text-2xl font-semibold rounded-lg">
            <h1>Total Reviews: <span><%= reviewData.length %></span></h1>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-6 py-10">

  <!-- Heading -->
  <h2 class="text-3xl font-bold text-gray-800 mb-6">
    Task Tracker
  </h2>


  <!-- Table Container -->
  <div class="overflow-x-auto bg-white shadow rounded-lg">

    <table class="w-full border-collapse">

      <!-- Header -->
      <thead class="bg-orange-500 text-white sticky top-0">

        <tr>

          <th class="text-left px-6 py-3 font-semibold">
            Task
          </th>

          <% days.forEach(day => { %>

            <th class="px-4 py-3 text-center font-semibold">

              <%= day.getDate() %>

            </th>

          <% }) %>

        </tr>

      </thead>



      <!-- Body -->
      <tbody class="divide-y">

        <% tasks.forEach(task => { %>

          <tr class="hover:bg-gray-50 transition">

            <!-- Task Name -->
            <td class="px-6 py-4 font-medium text-white bg-orange-500">

              <%= task.title %>

            </td>


            <% days.forEach(day => {

              const dateKey = new Date(day).setHours(0,0,0,0);
              const mapKey = `${task._id}_${dateKey}`;

              const isCompleted = completionMap[mapKey];
              const isToday = dateKey === today;

            %>


            <td class="text-center py-3">

              <% if(isCompleted){ %>

                <i class="fa-solid fa-circle-check text-green-500 text-lg"></i>

              <% } else if(isToday){ %>

                <form
                  action="/admin/task/<%= task._id %>/complete"
                  method="POST"
                >

                   <button
                      class="w-6 h-6 rounded-full border-2 border-orange-500 hover:bg-orange-500 hover:text-white flex items-center justify-center transition"
                    >

                      <i class="fa-solid fa-check text-xs"></i>

                    </button>

                </form>

              <% } else { %>

                <span class="text-gray-400">
                  —
                </span>

              <% } %>

            </td>

            <% }) %>

          </tr>

        <% }) %>

      </tbody>

    </table>

  </div>

</div>
<h2 class="text-3xl font-bold text-grat-800 mb-6">
    Your Track Record
  </h2>
<div class="grid grid-cols-3 mt-1 gap-6">

<div class="bg-white p-6 shadow rounded-lg">
<h2 class="text-xl font-bold text-gray-500">Today</h2>
<p><%= todayCompleted %> tasks</p>
<p><%= todayPercent %>% productivity</p>
</div>

<div class="bg-white p-6 shadow rounded-lg">
<h2 class="text-xl font-bold text-gray-500">This Week</h2>
<p><%= weekCompleted %> tasks</p>
<p><%= weekPercent %>% productivity</p>
</div>

<div class="bg-white p-6 shadow rounded-lg">
<h2 class="text-xl font-bold text-gray-500">This Month</h2>
<p><%= monthCompleted %> tasks</p>
<p><%= monthPercent %>% productivity</p>
</div>

</div>
  </body>
</html>
