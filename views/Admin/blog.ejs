<% layout("/Boilerplate/adminboilerplate.ejs") %>

<body class="bg-gray-100 min-h-screen p-6">

<section class="w-full py-10 bg-gray-50">

  <div class="max-w-7xl mx-auto px-6">

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">

      <% if(blogs.length === 0) { %>
        <p class="col-span-full text-center text-gray-500 text-lg font-semibold">
          No blogs published yet
        </p>
      <% } %>

      <% blogs.forEach((blog) => { %>

        <div class="bg-white rounded-xl shadow hover:shadow-lg transition overflow-hidden">

          <!-- Cover Image -->
          <!-- <% if(blog.coverImage) { %>
          <img 
            src="<%= blog.coverImage %>" 
            alt="<%= blog.title %>"
            class="w-full h-48 object-cover"
          >
          <% } %> -->

          <!-- Content -->
          <div class="p-5">

            <div class="flex justify-between items-center text-sm mb-2">

              <span class="bg-orange-100 text-orange-600 px-2 py-1 rounded font-medium">
                <%= blog.category %>
              </span>

              <span class="text-gray-500">
                <i class="fa-regular fa-clock"></i>
                <%= blog.readTime %> min read
              </span>

            </div>

            <h2 class="text-lg font-bold text-gray-800 mb-2 hover:text-orange-500 transition">
              <%= blog.title %>
            </h2>

            <p class="text-gray-600 text-sm mb-4">
              <%= blog.content.substring(0,120) %>...
            </p>

            <p class="text-gray-600 text-sm mb-4">
              <span class="font-bold">Views: </span><%= blog.views %>
            </p>

            <form action="/admin/<%= blog._id %>/blog?_method=DELETE" method="POST">
              <button class="w-full bg-orange-500 hover:bg-orange-600 text-white py-2 rounded-md font-semibold transition">
                Delete
              </button>
            </form>

          </div>

        </div>

      <% }) %>

    </div>


    <!-- Create Blog Form -->
    <div class="max-w-3xl mx-auto">

      <div class="bg-white shadow-lg rounded-xl">

        <div class="border-b border-gray-500 px-6 py-4">
          <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
            <i class="fa-solid fa-pen-to-square text-orange-500"></i>
            Create New Blog
          </h1>
          <p class="text-sm text-gray-500">
            Publish a new article to your portfolio blog
          </p>
        </div>

        <form action="/admin/create-blog" method="POST" class="p-6 space-y-4">

          <div>
            <label class="font-semibold">Title</label>
            <input name="title" required class="w-full border border-gray-400 rounded-lg px-3 py-2 focus:ring-2 focus:ring-orange-400 outline-none">
          </div>

          <div>
            <label class="font-semibold">Slug</label>
            <input name="slug" required class="w-full border border-gray-400 rounded-lg px-3 py-2 focus:ring-2 focus:ring-orange-400 outline-none">
          </div>

          <div class="grid grid-cols-2 gap-4">

            <div>
              <label class="font-semibold">Category</label>
              <input name="category" class="w-full border border-gray-400 rounded-lg px-3 py-2 focus:ring-2 focus:ring-orange-400 outline-none">
            </div>

            <div>
              <label class="font-semibold">Read Time</label>
              <input name="readTime" type="number" class="w-full border border-gray-400 rounded-lg px-3 py-2 focus:ring-2 focus:ring-orange-400 outline-none">
            </div>

          </div>

          <div>
            <label class="font-semibold">Tags</label>
            <input name="tags" class="w-full border border-gray-400 rounded-lg px-3 py-2 focus:ring-2 focus:ring-orange-400 outline-none">
          </div>

          <div>
            <label class="font-semibold">Cover Image URL</label>
            <input name="coverImage" class="w-full border border-gray-400 rounded-lg px-3 py-2 focus:ring-2 focus:ring-orange-400 outline-none">
          </div>

          <div>
            <label class="font-semibold">Content</label>
            <textarea name="content" rows="6" required class="w-full border border-gray-400 rounded-lg px-3 py-2 focus:ring-2 focus:ring-orange-400 outline-none"></textarea>
          </div>

          <div class="text-right">
            <button class="bg-orange-500 hover:bg-orange-600 text-white px-6 py-2 rounded-lg font-semibold">
              Publish Blog
            </button>
          </div>

        </form>

      </div>

    </div>

  </div>

</section>

</body>
</html>